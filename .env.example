# Database (Neon)
DATABASE_URL=postgresql://...pooled connection string...
DATABASE_URL_DIRECT=postgresql://...direct connection string...

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry
SENTRY_DSN_WEB=https://...@....ingest.sentry.io/...
SENTRY_DSN_API=https://...@....ingest.sentry.io/...

# Google OAuth (for Cognito federation)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# Discord OAuth (for Cognito federation)
DISCORD_CLIENT_ID=...
DISCORD_CLIENT_SECRET=...

# GDDL (per user, stored encrypted — this is for local testing only)
GDDL_API_KEY=...