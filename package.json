{
  "name": "infernolog",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deploy:staging": "pnpm --filter @infernolog/api deploy:staging && pnpm --filter @infernolog/web deploy:staging",
    "remove:staging": "pnpm --filter @infernolog/api remove:staging && pnpm --filter @infernolog/web remove:staging"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "globals": "^17.5.0",
    "turbo": "latest",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}
